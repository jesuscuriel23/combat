<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Duelo de Clases 1vs1</title>
  <style>
    :root{
      --bg1:#0f1b22;
      --bg2:#182933;
      --panel:#15232e;
      --panel2:#1d3140;
      --text:#eef7ff;
      --muted:#a9c0cf;
      --accent:#7ce0ff;
      --accent2:#9ef58f;
      --danger:#ff6b6b;
      --warn:#ffd166;
      --shadow: 0 12px 30px rgba(0,0,0,.35);
      --tile: 34px;
    }
    *{box-sizing:border-box}
    html,body{height:100%;margin:0;font-family:system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;color:var(--text);overflow:hidden}
    body{
      background:
        radial-gradient(circle at 20% 10%, #24435a 0%, transparent 30%),
        radial-gradient(circle at 80% 0%, #365c45 0%, transparent 25%),
        linear-gradient(180deg,var(--bg1),var(--bg2));
    }
    button{font:inherit}
    .screen{position:absolute;inset:0;display:none;align-items:center;justify-content:center;padding:18px}
    .screen.active{display:flex}
    .card{background:linear-gradient(180deg, rgba(23,38,49,.96), rgba(12,20,26,.96));border:1px solid rgba(255,255,255,.08);box-shadow:var(--shadow);border-radius:24px;max-width:1200px;width:min(1200px,100%);max-height:calc(100vh - 24px);overflow:auto}
    .start-wrap{display:grid;grid-template-columns:1.1fr .9fr;min-height:min(92vh,860px)}
    .hero{padding:42px 38px;background:
      radial-gradient(circle at 15% 25%, rgba(124,224,255,.18), transparent 25%),
      radial-gradient(circle at 85% 15%, rgba(158,245,143,.13), transparent 24%),
      linear-gradient(135deg, rgba(20,37,50,.96), rgba(10,18,24,.96));position:relative}
    .hero:before,.hero:after{content:"";position:absolute;border-radius:999px;filter:blur(2px);opacity:.7}
    .hero:before{width:180px;height:180px;right:20px;top:20px;background:radial-gradient(circle, rgba(124,224,255,.3), transparent 65%)}
    .hero:after{width:140px;height:140px;left:24px;bottom:30px;background:radial-gradient(circle, rgba(158,245,143,.2), transparent 65%)}
    .title{font-size:clamp(40px,6vw,68px);line-height:.95;margin:0 0 14px;font-weight:900;letter-spacing:-.04em}
    .subtitle{font-size:18px;color:var(--muted);max-width:620px;line-height:1.55}
    .big-cta{display:flex;gap:12px;flex-wrap:wrap;margin-top:28px}
    .btn{border:0;border-radius:18px;padding:14px 18px;font-weight:800;cursor:pointer;transition:.2s transform,.2s opacity,.2s box-shadow}
    .btn:hover{transform:translateY(-2px)}
    .btn-primary{background:linear-gradient(135deg,#7ce0ff,#9ef58f);color:#09131a;box-shadow:0 10px 24px rgba(124,224,255,.18)}
    .btn-secondary{background:#223746;color:#e8f6ff;border:1px solid rgba(255,255,255,.08)}
    .panel-side{padding:28px;border-left:1px solid rgba(255,255,255,.07);display:flex;flex-direction:column;gap:18px}
    .section-title{font-size:18px;font-weight:900;letter-spacing:.03em;text-transform:uppercase;color:#d6ebf8}
    .tips{display:grid;gap:12px}
    .tip{background:linear-gradient(180deg, rgba(31,49,63,.95), rgba(18,29,38,.95));padding:14px 16px;border-radius:18px;border:1px solid rgba(255,255,255,.07);line-height:1.5}
    .tip b{display:block;margin-bottom:4px;color:#fff}
    .classes{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-top:10px}
    .class-card{background:linear-gradient(180deg, rgba(31,49,63,.95), rgba(18,29,38,.95));border:1px solid rgba(255,255,255,.08);border-radius:20px;padding:14px;cursor:pointer;transition:.2s transform,.2s border-color,.2s box-shadow;min-height:190px;position:relative;overflow:hidden}
    .class-card:hover{transform:translateY(-3px);box-shadow:0 14px 28px rgba(0,0,0,.28)}
    .class-card.selected{border-color:rgba(124,224,255,.6);box-shadow:0 0 0 2px rgba(124,224,255,.18) inset}
    .class-badge{display:inline-flex;align-items:center;gap:8px;padding:7px 10px;border-radius:999px;background:rgba(255,255,255,.06);font-weight:800;font-size:13px}
    .class-name{font-size:24px;font-weight:900;margin:10px 0 8px}
    .class-desc{font-size:14px;line-height:1.5;color:var(--muted)}
    .moves{margin-top:12px;font-size:13px;line-height:1.45;color:#dfefff}
    .moves span{display:block;margin-top:6px;color:#a9c0cf}
    .selection-bar{margin-top:auto;display:flex;gap:12px;flex-wrap:wrap;align-items:center;justify-content:space-between}
    .pill{padding:10px 14px;border-radius:999px;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.08);color:#e8f5ff;font-weight:700}
    .game-wrap{position:absolute;inset:0;display:none;flex-direction:column}
    .game-wrap.active{display:flex}
    .hud{display:grid;grid-template-columns:1fr auto 1fr;gap:14px;padding:14px 14px 10px}
    .hud-panel{background:linear-gradient(180deg, rgba(20,31,40,.95), rgba(11,18,24,.95));border:1px solid rgba(255,255,255,.07);border-radius:20px;padding:12px 14px;box-shadow:var(--shadow)}
    .player-top{display:flex;justify-content:space-between;align-items:center;gap:10px;margin-bottom:10px}
    .player-name{font-weight:900}
    .player-meta{font-size:13px;color:var(--muted)}
    .hpbar{height:16px;background:rgba(255,255,255,.08);border-radius:999px;overflow:hidden;border:1px solid rgba(255,255,255,.08)}
    .hpfill{height:100%;width:100%;border-radius:999px;background:linear-gradient(90deg,#ff8a8a,#ff5f6d);transition:width .18s ease}
    .cooldowns{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-top:10px}
    .cd{border-radius:16px;padding:8px 6px;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.06);text-align:center;min-height:70px;position:relative;overflow:hidden}
    .cd .key{font-size:12px;font-weight:900;opacity:.9}
    .cd .label{font-size:11px;color:var(--muted);line-height:1.15;margin-top:4px}
    .cd .time{position:absolute;inset:auto 6px 6px auto;font-size:12px;font-weight:900;color:#fff;background:rgba(0,0,0,.3);padding:2px 6px;border-radius:999px}
    .center-hud{display:flex;align-items:center;justify-content:center}
    .score{display:flex;flex-direction:column;align-items:center;gap:7px;background:linear-gradient(180deg, rgba(26,44,58,.95), rgba(16,24,31,.95));border:1px solid rgba(255,255,255,.07);border-radius:20px;padding:12px 18px;min-width:220px}
    .score strong{font-size:14px;color:#dff3ff;letter-spacing:.05em;text-transform:uppercase}
    .roundmsg{font-size:18px;font-weight:900;color:#fff;min-height:26px}
    .arena-shell{position:relative;flex:1;display:flex;align-items:center;justify-content:center;padding:10px 14px 18px}
    .arena{position:relative;width:min(100%, min(96vw, 1200px));height:min(100%, 720px);max-height:720px;border-radius:28px;overflow:hidden;border:1px solid rgba(255,255,255,.08);box-shadow:var(--shadow);background:#0f1d26}
    canvas{display:block;width:100%;height:100%}
    .overlay{position:absolute;inset:0;pointer-events:none}
    .toast{position:absolute;left:50%;top:16px;transform:translateX(-50%);padding:10px 14px;border-radius:999px;background:rgba(0,0,0,.45);border:1px solid rgba(255,255,255,.1);font-weight:800;opacity:0;transition:opacity .2s ease}
    .tutorial-screen{padding:30px;display:grid;place-items:center}
    .tutorial-card{max-width:980px;width:100%;background:linear-gradient(180deg, rgba(22,36,47,.98), rgba(10,16,22,.98));border:1px solid rgba(255,255,255,.08);border-radius:24px;padding:22px;box-shadow:var(--shadow)}
    .tutorial-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-top:16px}
    .note{background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.07);padding:14px;border-radius:18px;line-height:1.5;color:#d9ebf7}
    .kbd{display:inline-block;min-width:30px;padding:2px 8px;border-radius:8px;background:#203543;border:1px solid rgba(255,255,255,.12);font-weight:900;text-align:center}
    .mini{color:var(--muted);font-size:13px;line-height:1.45}
    @media (max-width: 960px){
      .start-wrap{grid-template-columns:1fr}
      .panel-side{border-left:0;border-top:1px solid rgba(255,255,255,.07)}
      .classes,.tutorial-grid{grid-template-columns:1fr}
      .hud{grid-template-columns:1fr}
      .center-hud{order:-1}
    }
  </style>
</head>
<body>
  <div id="startScreen" class="screen active">
    <div class="card start-wrap">
      <div class="hero">
        <h1 class="title">Duelo de Clases<br>1vs1</h1>
        <div class="subtitle">Un juego local en el mismo teclado. Elige clase, muévete cuadro por cuadro, recoge objetos, usa habilidades con cooldown y derrota a tu rival.</div>
        <div class="big-cta">
          <button id="startBtn" class="btn btn-primary">Jugar ahora</button>
          <button id="tutorialBtn" class="btn btn-secondary">Ver tutorial</button>
        </div>
        <div style="margin-top:28px" class="section-title">Elige tu clase</div>
        <div class="classes" id="classGrid"></div>
      </div>
      <div class="panel-side">
        <div class="section-title">Cómo se juega</div>
        <div class="tips">
          <div class="tip"><b>Jugador 1</b>Flechas para moverse. <span class="mini">Movimientos: 1, 2, 3 y ataque con 4.</span></div>
          <div class="tip"><b>Jugador 2</b>W A S D para moverse. <span class="mini">Movimientos: 8, 9, 0 y ataque con 7.</span></div>
          <div class="tip"><b>Mapa</b>El agua te vuelve más lento. Árboles y rocas bloquean el paso.</div>
          <div class="tip"><b>Meta</b>Baja la vida del enemigo a 0 con ataques, habilidades y control del mapa.</div>
        </div>
        <div class="tip"><b>Consejo</b>Elige una clase que combine con tu estilo: presión, distancia o control.</div>
        <div class="selection-bar">
          <div class="pill" id="selectedPill">Clase seleccionada: Guerrero</div>
          <div class="pill">Juego local en el mismo teclado</div>
        </div>
      </div>
    </div>
  </div>

  <div id="tutorialScreen" class="screen tutorial-screen">
    <div class="tutorial-card">
      <div style="display:flex;justify-content:space-between;align-items:center;gap:12px;flex-wrap:wrap">
        <div>
          <div class="section-title">Tutorial</div>
          <h2 style="margin:6px 0 0;font-size:30px">Todo lo básico en un vistazo</h2>
        </div>
        <button id="backBtn" class="btn btn-secondary">Volver</button>
      </div>
      <div class="tutorial-grid">
        <div class="note"><b>Movimiento</b><br>Cada pulsación mueve exactamente 1 cuadro, siempre que no haya muro, árbol o roca.</div>
        <div class="note"><b>Combate</b><br>El ataque básico golpea el bloque frente a ti. Las habilidades usan cooldown.</div>
        <div class="note"><b>Objetos</b><br>Pociones curan, boosts aumentan velocidad y escudos reducen daño.</div>
        <div class="note"><b>Victoria</b><br>Gana quien deje la vida del enemigo en 0.</div>
      </div>
      <div style="margin-top:16px" class="note"><b>Atajos</b><br><span class="kbd">1/8</span> habilidad 1 · <span class="kbd">2/9</span> habilidad 2 · <span class="kbd">3/0</span> habilidad 3 · <span class="kbd">4/7</span> ataque básico</div>
      <div style="margin-top:18px;display:flex;justify-content:flex-end">
        <button id="playBtn" class="btn btn-primary">Empezar partida</button>
      </div>
    </div>
  </div>

  <div id="gameScreen" class="game-wrap">
    <div class="hud">
      <div class="hud-panel" id="p1Hud"></div>
      <div class="center-hud"><div class="score"><strong>Duelo en curso</strong><div class="roundmsg" id="roundMsg">¡Prepárate!</div></div></div>
      <div class="hud-panel" id="p2Hud"></div>
    </div>
    <div class="arena-shell">
      <div class="arena" id="arena">
        <canvas id="gameCanvas"></canvas>
        <div class="overlay" id="overlay"></div>
        <div class="toast" id="toast">Selecciona clase y comienza</div>
      </div>
    </div>
  </div>

<script>
(() => {
  const TILE = 34;
  const MAP_W = 24;
  const MAP_H = 18;
  const canvas = document.getElementById('gameCanvas');
  const ctx = canvas.getContext('2d');
  const toast = document.getElementById('toast');
  const roundMsg = document.getElementById('roundMsg');
  const classGrid = document.getElementById('classGrid');
  const selectedPill = document.getElementById('selectedPill');
  const startScreen = document.getElementById('startScreen');
  const tutorialScreen = document.getElementById('tutorialScreen');
  const gameScreen = document.getElementById('gameScreen');
  const arena = document.getElementById('arena');
  const p1Hud = document.getElementById('p1Hud');
  const p2Hud = document.getElementById('p2Hud');
  const startBtn = document.getElementById('startBtn');
  const tutorialBtn = document.getElementById('tutorialBtn');
  const backBtn = document.getElementById('backBtn');
  const playBtn = document.getElementById('playBtn');

  const CLASSES = {
    warrior: { name:'Guerrero', icon:'⚔️', weapon:'🗡️', color:'#ffd166', hp:140, atk:24, desc:'Daño fuerte y presión frontal.', skills:[
      {key:'1', name:'Espadazo', cd:4}, {key:'2', name:'Estocada', cd:5}, {key:'3', name:'Buff de guerra', cd:12}, {key:'4', name:'Puño', cd:1.1}
    ]},
    archer: { name:'Arquero', icon:'🏹', weapon:'🏹', color:'#9ef58f', hp:112, atk:19, desc:'Controla la distancia y el terreno.', skills:[
      {key:'1', name:'Flechazo', cd:2.5}, {key:'2', name:'Triple flechazo', cd:5}, {key:'3', name:'Trampa', cd:8}, {key:'4', name:'Puño', cd:1.1}
    ]},
    mage: { name:'Mago', icon:'✨', weapon:'🔮', color:'#7ce0ff', hp:100, atk:17, desc:'Control, persecución y teletransporte.', skills:[
      {key:'1', name:'Bola de fuego', cd:4}, {key:'2', name:'Tormenta', cd:8}, {key:'3', name:'Teletransportación', cd:6}, {key:'4', name:'Puño', cd:1.1}
    ]}
  };

  const state = {
    running:false,
    selectedClass:'warrior',
    map:[],
    particles:[],
    projectiles:[],
    storms:[],
    players:[],
    pressed:new Set(),
    last:performance.now(),
    winner:null,
    introDone:false,
    shake:0
  };

  function resizeCanvas(){
    const r = arena.getBoundingClientRect();
    canvas.width = Math.floor(r.width * devicePixelRatio);
    canvas.height = Math.floor(r.height * devicePixelRatio);
    canvas.style.width = r.width + 'px';
    canvas.style.height = r.height + 'px';
    ctx.setTransform(devicePixelRatio,0,0,devicePixelRatio,0,0);
  }
  window.addEventListener('resize', resizeCanvas);

  const rand = (a,b) => Math.random()*(b-a)+a;
  const clamp = (v,min,max) => Math.max(min, Math.min(max, v));
  const choice = arr => arr[Math.floor(Math.random()*arr.length)];
  const inBounds = (x,y) => x>=0 && y>=0 && x<MAP_W && y<MAP_H;
  const tileAt = (x,y) => inBounds(x,y) ? state.map[y][x] : {type:'rock', item:null, trap:null};
  const isBlocked = (x,y) => {
    const t = tileAt(x,y).type;
    return t === 'tree' || t === 'rock';
  };
  const isWater = (x,y) => tileAt(x,y).type === 'water';

  function showToast(text, ms=1400){
    toast.textContent = text;
    toast.style.opacity = '1';
    clearTimeout(showToast._t);
    showToast._t = setTimeout(() => toast.style.opacity = '0', ms);
  }

  function buildClassCards(){
    const order = ['warrior','archer','mage'];
    classGrid.innerHTML = '';
    for(const id of order){
      const c = CLASSES[id];
      const el = document.createElement('div');
      el.className = 'class-card' + (id === state.selectedClass ? ' selected' : '');
      el.innerHTML = `
        <div class="class-badge"><span>${c.icon}</span><span>${c.name}</span></div>
        <div class="class-name">${c.name}</div>
        <div class="class-desc">${c.desc}</div>
        <div class="moves">
          <b>Habilidades</b>
          <span><b>${c.skills[0].key}</b> ${c.skills[0].name}</span>
          <span><b>${c.skills[1].key}</b> ${c.skills[1].name}</span>
          <span><b>${c.skills[2].key}</b> ${c.skills[2].name}</span>
          <span><b>${c.skills[3].key}</b> ${c.skills[3].name}</span>
        </div>`;
      el.onclick = () => {
        state.selectedClass = id;
        selectedPill.textContent = `Clase seleccionada: ${c.name}`;
        buildClassCards();
      };
      classGrid.appendChild(el);
    }
  }

  function makeMap(){
    const map = [];
    for(let y=0;y<MAP_H;y++){
      const row = [];
      for(let x=0;x<MAP_W;x++){
        let type = 'grass';
        const edge = x===0 || y===0 || x===MAP_W-1 || y===MAP_H-1;
        if(edge) type = Math.random()<0.65 ? 'rock' : 'tree';
        else {
          const r = Math.random();
          if(r < 0.10) type = 'water';
          else if(r < 0.16) type = 'tree';
          else if(r < 0.20) type = 'rock';
        }
        row.push({type, item:null, trap:null});
      }
      map.push(row);
    }
    [[2,2],[3,2],[2,3],[21,15],[20,15],[21,14]].forEach(([x,y]) => { if(map[y] && map[y][x]) map[y][x].type = 'grass'; });
    const itemTypes = ['heal','speed','shield'];
    for(let i=0;i<18;i++){
      let x,y;
      do {
        x = 1 + Math.floor(Math.random()*(MAP_W-2));
        y = 1 + Math.floor(Math.random()*(MAP_H-2));
      } while (['tree','rock'].includes(map[y][x].type) || (x<5 && y<5) || (x>18 && y>12));
      map[y][x].item = choice(itemTypes);
    }
    return map;
  }

  function makePlayer(id, x, y, cls, controls){
    return {
      id,
      x, y,
      px:x*TILE + TILE/2,
      py:y*TILE + TILE/2,
      fromX:x, fromY:y, toX:x, toY:y,
      moving:false,
      moveStart:0,
      moveDur:160,
      classId:Object.keys(CLASSES).find(k => CLASSES[k] === cls),
      cls,
      controls,
      hp:cls.hp,
      maxHp:cls.hp,
      baseAtk:cls.atk,
      attackMult:1,
      buffUntil:0,
      speedBonusUntil:0,
      shieldUntil:0,
      stunnedUntil:0,
      frozenUntil:0,
      cooldowns:{s1:0,s2:0,s3:0,atk:0},
      facing:id===1 ? {x:1,y:0} : {x:-1,y:0},
      alive:true,
      color:cls.color,
      hitFlash:0,
      teleportMark:null
    };
  }

  function spawnPlayers(){
    const p1Class = CLASSES[state.selectedClass];
    const p2Class = choice(Object.keys(CLASSES).filter(k => k !== state.selectedClass));
    state.players = [
      makePlayer(1, 2, 2, p1Class, {up:'ArrowUp',down:'ArrowDown',left:'ArrowLeft',right:'ArrowRight',s1:'1',s2:'2',s3:'3',atk:'4'}),
      makePlayer(2, 21, 15, CLASSES[p2Class], {up:'w',down:'s',left:'a',right:'d',s1:'8',s2:'9',s3:'0',atk:'7'})
    ];
  }

  function playerAt(x,y, ignoreId=null){
    return state.players.find(p => p.alive && p.id !== ignoreId && p.x === x && p.y === y);
  }

  function burst(x,y,color){
    const px = x*TILE + TILE/2, py = y*TILE + TILE/2;
    for(let i=0;i<12;i++){
      state.particles.push({x:px,y:py,vx:rand(-2.8,2.8),vy:rand(-2.8,2.8),life:rand(.35,.7),c:color});
    }
  }

  function damagePlayer(target, amount, srcId=null){
    if(!target || !target.alive) return;
    if(performance.now() < target.shieldUntil) amount *= 0.6;
    amount = Math.max(1, Math.round(amount));
    target.hp = clamp(target.hp - amount, 0, target.maxHp);
    target.hitFlash = 0.18;
    state.shake = Math.min(12, state.shake + 5);
    burst(target.x, target.y, amount > 20 ? '#ffd166' : '#ff8fa3');
    if(target.hp <= 0){
      target.alive = false;
      endGame(srcId ?? (target.id === 1 ? 2 : 1));
    }
  }

  function endGame(winnerId){
    state.winner = winnerId;
    state.introDone = false;
    roundMsg.textContent = `Gana Jugador ${winnerId}`;
    showToast(`¡Ganó el Jugador ${winnerId}!`, 3000);
    setTimeout(() => {
      alert(`¡Ganó el Jugador ${winnerId}!`);
      startScreen.classList.add('active');
      gameScreen.classList.remove('active');
      buildClassCards();
    }, 250);
  }

  function canAct(p){ return p.alive && performance.now() > p.stunnedUntil && performance.now() > p.frozenUntil; }
  function ready(p, slot){ return performance.now() >= p.cooldowns[slot]; }
  function setCooldown(p, slot, seconds){ p.cooldowns[slot] = performance.now() + seconds*1000; }
  function facingPos(p, n=1){ return {x:p.x + p.facing.x*n, y:p.y + p.facing.y*n}; }

  function applyItem(p, item, x, y){
    const cell = tileAt(x,y);
    cell.item = null;
    if(item === 'heal'){
      p.hp = clamp(p.hp + 24, 0, p.maxHp);
      burst(x,y,'#ff8fb1');
      showToast(`Jugador ${p.id}: curación`);
    }
    if(item === 'speed'){
      p.speedBonusUntil = performance.now() + 8000;
      burst(x,y,'#7ce0ff');
      showToast(`Jugador ${p.id}: velocidad aumentada`);
    }
    if(item === 'shield'){
      p.shieldUntil = performance.now() + 7000;
      burst(x,y,'#ffd166');
      showToast(`Jugador ${p.id}: escudo activado`);
    }
  }

  function triggerTrap(victim, trap){
    damagePlayer(victim, 16, trap.owner);
    victim.stunnedUntil = performance.now() + 5000;
    showToast(`Jugador ${victim.id} cayó en una trampa`);
    burst(victim.x, victim.y, '#ff6b6b');
  }

  function startGame(){
    state.running = true;
    state.winner = null;
    state.map = makeMap();
    state.particles = [];
    state.projectiles = [];
    state.storms = [];
    state.shake = 0;
    state.introDone = false;
    state.pressed.clear();
    spawnPlayers();
    startScreen.classList.remove('active');
    tutorialScreen.classList.remove('active');
    gameScreen.classList.add('active');
    resizeCanvas();
    updateHUD();
    roundMsg.textContent = '3';
    showToast('¡Empieza en 3!');
    setTimeout(() => { if(state.running && !state.winner){ roundMsg.textContent = '2'; showToast('2'); } }, 1000);
    setTimeout(() => { if(state.running && !state.winner){ roundMsg.textContent = '1'; showToast('1'); } }, 2000);
    setTimeout(() => { if(state.running && !state.winner){ roundMsg.textContent = '¡YA!'; showToast('¡YA!'); state.introDone = true; } }, 3000);
  }

  function attemptMove(p, dx, dy){
    if(!state.running || !state.introDone || !canAct(p) || p.moving) return false;
    const nx = p.x + dx, ny = p.y + dy;
    p.facing = {x:dx, y:dy};
    if(!inBounds(nx,ny) || isBlocked(nx,ny)) return false;
    if(playerAt(nx,ny,p.id)) return false;
    p.fromX = p.x; p.fromY = p.y; p.toX = nx; p.toY = ny;
    p.moving = true;
    p.moveStart = performance.now();
    p.moveDur = isWater(nx,ny) ? 255 : 165;
    const item = tileAt(nx,ny).item;
    if(item) applyItem(p, item, nx, ny);
    if(tileAt(nx,ny).trap && tileAt(nx,ny).trap.owner !== p.id){
      const trap = tileAt(nx,ny).trap;
      tileAt(nx,ny).trap = null;
      triggerTrap(p, trap);
    }
    return true;
  }

  function finishMove(p){
    p.x = p.toX; p.y = p.toY;
    p.px = p.x*TILE + TILE/2;
    p.py = p.y*TILE + TILE/2;
    p.moving = false;
  }

  function attackBasic(p, dmgMul=1){
    if(!canAct(p) || !ready(p,'atk') || !state.introDone) return;
    setCooldown(p,'atk',1.1);
    const fp = facingPos(p,1);
    const target = playerAt(fp.x, fp.y, p.id);
    p.hitFlash = 0.08;
    if(target) damagePlayer(target, p.baseAtk * p.attackMult * dmgMul, p.id);
    else burst(fp.x, fp.y, '#d7ebff');
  }

  function warriorSkill1(p){
    if(!ready(p,'s1') || !canAct(p)) return;
    setCooldown(p,'s1',4);
    const a = facingPos(p,1), b = facingPos(p,2);
    [a,b].forEach(pos => {
      const t = playerAt(pos.x, pos.y, p.id);
      if(t) damagePlayer(t, 28 * p.attackMult, p.id);
      burst(pos.x, pos.y, '#ffd166');
    });
  }
  function warriorSkill2(p){
    if(!ready(p,'s2') || !canAct(p)) return;
    setCooldown(p,'s2',5);
    let nx = p.x, ny = p.y;
    for(let i=1;i<=4;i++){
      const tx = p.x + p.facing.x*i, ty = p.y + p.facing.y*i;
      if(!inBounds(tx,ty) || isBlocked(tx,ty)) break;
      nx = tx; ny = ty;
      const t = playerAt(tx,ty,p.id);
      if(t) damagePlayer(t, 25 * p.attackMult, p.id);
    }
    p.x = nx; p.y = ny; p.px = nx*TILE + TILE/2; p.py = ny*TILE + TILE/2;
    burst(nx,ny,'#ffd166');
  }
  function warriorSkill3(p){
    if(!ready(p,'s3') || !canAct(p)) return;
    setCooldown(p,'s3',12);
    p.attackMult = 1.5;
    p.buffUntil = performance.now() + 10000;
    showToast(`Jugador ${p.id}: buff de guerra`);
  }

  function archerSkill1(p){
    if(!ready(p,'s1') || !canAct(p)) return;
    setCooldown(p,'s1',2.5);
    spawnProjectile(p, {vx:p.facing.x, vy:p.facing.y, range:8, color:'#b8ff7a', type:'arrow', damage:20});
  }
  function archerSkill2(p){
    if(!ready(p,'s2') || !canAct(p)) return;
    setCooldown(p,'s2',5);
    const up = {x:-p.facing.y, y:p.facing.x};
    const down = {x:p.facing.y, y:-p.facing.x};
    spawnProjectile(p, {vx:p.facing.x, vy:p.facing.y, range:3, color:'#b8ff7a', type:'arrow', damage:16});
    spawnProjectile(p, {vx:p.facing.x+up.x, vy:p.facing.y+up.y, range:3, color:'#caff9a', type:'arrow', damage:14});
    spawnProjectile(p, {vx:p.facing.x+down.x, vy:p.facing.y+down.y, range:3, color:'#caff9a', type:'arrow', damage:14});
  }
  function archerSkill3(p){
    if(!ready(p,'s3') || !canAct(p)) return;
    setCooldown(p,'s3',8);
    const enemy = state.players.find(o => o.id !== p.id && o.alive);
    if(!enemy) return;
    tileAt(enemy.x, enemy.y).trap = {owner:p.id, time:performance.now()};
    showToast(`Jugador ${p.id}: trampa colocada`);
    burst(enemy.x, enemy.y, '#9ef58f');
  }

  function mageSkill1(p){
    if(!ready(p,'s1') || !canAct(p)) return;
    setCooldown(p,'s1',4);
    const enemy = state.players.find(o => o.id !== p.id && o.alive);
    if(!enemy) return;
    state.projectiles.push({type:'homing', owner:p.id, x:p.x, y:p.y, px:p.x*TILE+TILE/2, py:p.y*TILE+TILE/2, damage:22, speed:0.12, life:9, color:'#7ce0ff'});
    showToast(`Jugador ${p.id}: bola de fuego`);
  }
  function mageSkill2(p){
    if(!ready(p,'s2') || !canAct(p)) return;
    setCooldown(p,'s2',8);
    const enemy = state.players.find(o => o.id !== p.id && o.alive);
    if(!enemy) return;
    const minX = clamp(enemy.x-1, 1, MAP_W-5);
    const minY = clamp(enemy.y-1, 1, MAP_H-5);
    for(let yy=minY; yy<minY+4; yy++){
      for(let xx=minX; xx<minX+4; xx++){
        state.storms.push({x:xx,y:yy,owner:p.id,until:performance.now()+5500,last:0});
      }
    }
    showToast(`Jugador ${p.id}: tormenta invocada`);
  }
  function mageSkill3(p){
    if(!ready(p,'s3') || !canAct(p)) return;
    setCooldown(p,'s3',6);
    if(!p.teleportMark){
      p.teleportMark = {x:p.x, y:p.y};
      showToast(`Jugador ${p.id}: marca creada`);
    } else {
      const mark = p.teleportMark;
      if(!isBlocked(mark.x, mark.y)){
        p.x = mark.x; p.y = mark.y; p.px = mark.x*TILE + TILE/2; p.py = mark.y*TILE + TILE/2;
        burst(p.x, p.y, '#7ce0ff');
        showToast(`Jugador ${p.id}: teletransportado`);
      }
      p.teleportMark = null;
    }
  }

  function spawnProjectile(p, opt){
    state.projectiles.push({
      owner:p.id,
      type:opt.type || 'arrow',
      x:p.x,
      y:p.y,
      px:p.x*TILE + TILE/2,
      py:p.y*TILE + TILE/2,
      vx:Math.sign(opt.vx || p.facing.x),
      vy:Math.sign(opt.vy || p.facing.y),
      damage:opt.damage,
      range:opt.range,
      color:opt.color,
      dist:0,
      life:999
    });
  }

  function handleSpecial(p, slot){
    if(p.classId === 'warrior'){
      if(slot === 's1') warriorSkill1(p);
      if(slot === 's2') warriorSkill2(p);
      if(slot === 's3') warriorSkill3(p);
    } else if(p.classId === 'archer'){
      if(slot === 's1') archerSkill1(p);
      if(slot === 's2') archerSkill2(p);
      if(slot === 's3') archerSkill3(p);
    } else if(p.classId === 'mage'){
      if(slot === 's1') mageSkill1(p);
      if(slot === 's2') mageSkill2(p);
      if(slot === 's3') mageSkill3(p);
    }
  }

  function handleKeyPress(key){
    if(!state.running || !state.introDone || state.winner) return;
    const p1 = state.players[0];
    const p2 = state.players[1];
    const lower = key.toLowerCase();

    if(key === 'ArrowUp') attemptMove(p1,0,-1);
    if(key === 'ArrowDown') attemptMove(p1,0,1);
    if(key === 'ArrowLeft') attemptMove(p1,-1,0);
    if(key === 'ArrowRight') attemptMove(p1,1,0);
    if(key === '1') handleSpecial(p1,'s1');
    if(key === '2') handleSpecial(p1,'s2');
    if(key === '3') handleSpecial(p1,'s3');
    if(key === '4') attackBasic(p1);

    if(lower === 'w') attemptMove(p2,0,-1);
    if(lower === 's') attemptMove(p2,0,1);
    if(lower === 'a') attemptMove(p2,-1,0);
    if(lower === 'd') attemptMove(p2,1,0);
    if(key === '8') handleSpecial(p2,'s1');
    if(key === '9') handleSpecial(p2,'s2');
    if(key === '0') handleSpecial(p2,'s3');
    if(key === '7') attackBasic(p2);
  }

  function updateProjectiles(dt){
    const enemyOf = id => state.players.find(p => p.id !== id && p.alive);
    state.projectiles = state.projectiles.filter(pr => {
      if(pr.type === 'homing'){
        const enemy = enemyOf(pr.owner);
        if(!enemy) return false;
        const ex = enemy.x*TILE + TILE/2;
        const ey = enemy.y*TILE + TILE/2;
        const dx = ex - pr.px;
        const dy = ey - pr.py;
        const len = Math.hypot(dx,dy) || 1;
        pr.px += (dx/len) * 160 * dt;
        pr.py += (dy/len) * 160 * dt;
        if(Math.hypot(ex-pr.px, ey-pr.py) < 10){
          damagePlayer(enemy, pr.damage, pr.owner);
          burst(enemy.x, enemy.y, '#7ce0ff');
          return false;
        }
        pr.life -= dt;
        return pr.life > 0;
      }

      pr.px += pr.vx * 210 * dt;
      pr.py += pr.vy * 210 * dt;
      const gx = Math.round((pr.px - TILE/2) / TILE);
      const gy = Math.round((pr.py - TILE/2) / TILE);
      pr.dist += 6.2 * dt;
      if(!inBounds(gx,gy) || isBlocked(gx,gy) || pr.dist >= pr.range){
        return false;
      }
      const enemy = playerAt(gx,gy,pr.owner);
      if(enemy){
        damagePlayer(enemy, pr.damage, pr.owner);
        return false;
      }
      return true;
    });
  }

  function updateStorms(now){
    state.storms = state.storms.filter(s => now < s.until);
    for(const s of state.storms){
      if(now - s.last > 900){
        s.last = now;
        const enemy = state.players.find(p => p.id !== s.owner && p.alive);
        if(enemy && enemy.x === s.x && enemy.y === s.y) damagePlayer(enemy, 10, s.owner);
      }
    }
  }

  function updatePlayers(now){
    for(const p of state.players){
      if(!p) continue;
      if(p.hitFlash > 0) p.hitFlash -= 0.03;
      if(p.buffUntil && now > p.buffUntil){ p.attackMult = 1; p.buffUntil = 0; }
      if(p.moving){
        const t = clamp((now - p.moveStart) / p.moveDur, 0, 1);
        const ease = 1 - Math.pow(1 - t, 3);
        p.px = (p.fromX + (p.toX - p.fromX) * ease) * TILE + TILE/2;
        p.py = (p.fromY + (p.toY - p.fromY) * ease) * TILE + TILE/2;
        if(t >= 1) finishMove(p);
      }
    }
  }

  function updateHUD(){
    const p1 = state.players[0], p2 = state.players[1];
    if(!p1 || !p2) return;
    p1Hud.innerHTML = hudMarkup(p1);
    p2Hud.innerHTML = hudMarkup(p2);
  }

  function hudMarkup(p){
    const now = performance.now();
    const cd = k => Math.max(0, (p.cooldowns[k] - now) / 1000);
    const skills = p.cls.skills;
    return `
      <div class="player-top">
        <div>
          <div class="player-name">Jugador ${p.id} · ${p.cls.name}</div>
          <div class="player-meta">${p.cls.icon} ${p.cls.desc}</div>
        </div>
        <div style="font-size:26px">${p.cls.icon}</div>
      </div>
      <div class="hpbar"><div class="hpfill" style="width:${(p.hp/p.maxHp)*100}%"></div></div>
      <div style="margin-top:8px;font-size:13px;color:var(--muted)">${p.hp}/${p.maxHp} HP</div>
      <div class="cooldowns">
        <div class="cd"><div class="key">${p.id===1?'1':'8'}</div><div class="label">${skills[0].name}</div><div class="time">${cd('s1')>0 ? cd('s1').toFixed(1) : 'OK'}</div></div>
        <div class="cd"><div class="key">${p.id===1?'2':'9'}</div><div class="label">${skills[1].name}</div><div class="time">${cd('s2')>0 ? cd('s2').toFixed(1) : 'OK'}</div></div>
        <div class="cd"><div class="key">${p.id===1?'3':'0'}</div><div class="label">${skills[2].name}</div><div class="time">${cd('s3')>0 ? cd('s3').toFixed(1) : 'OK'}</div></div>
        <div class="cd"><div class="key">${p.id===1?'4':'7'}</div><div class="label">Puño</div><div class="time">${cd('atk')>0 ? cd('atk').toFixed(1) : 'OK'}</div></div>
      </div>
      <div style="margin-top:8px;font-size:12px;color:var(--muted)">Escudo: ${p.shieldUntil>performance.now() ? 'activo' : 'no'} · Buff: ${p.buffUntil>performance.now() ? 'sí' : 'no'}</div>
    `;
  }

  function drawTile(x,y,t){
    const px = x*TILE, py = y*TILE;
    if(t.type === 'grass'){
      const g = ctx.createLinearGradient(px,py,px,py+TILE);
      g.addColorStop(0,'#4b8f43');
      g.addColorStop(1,'#35692f');
      ctx.fillStyle = g;
      ctx.fillRect(px,py,TILE,TILE);
      ctx.fillStyle = 'rgba(255,255,255,.05)';
      ctx.fillRect(px+3,py+4,4,4);
      ctx.fillRect(px+18,py+20,5,5);
    } else if(t.type === 'water'){
      const g = ctx.createLinearGradient(px,py,px+TILE,py+TILE);
      g.addColorStop(0,'#2e7fb6');
      g.addColorStop(1,'#1b4d79');
      ctx.fillStyle = g;
      ctx.fillRect(px,py,TILE,TILE);
      ctx.fillStyle = 'rgba(255,255,255,.14)';
      ctx.beginPath(); ctx.arc(px+10,py+12,3,0,Math.PI*2); ctx.fill();
      ctx.beginPath(); ctx.arc(px+24,py+22,2.6,0,Math.PI*2); ctx.fill();
    } else if(t.type === 'tree'){
      ctx.fillStyle = '#4b8f43'; ctx.fillRect(px,py,TILE,TILE);
      ctx.fillStyle = '#7a4d2d'; ctx.fillRect(px+13,py+13,8,13);
      ctx.fillStyle = '#2e6d36'; ctx.beginPath(); ctx.arc(px+17,py+11,11,0,Math.PI*2); ctx.fill();
      ctx.fillStyle = 'rgba(255,255,255,.08)'; ctx.beginPath(); ctx.arc(px+13,py+8,5,0,Math.PI*2); ctx.fill();
    } else {
      ctx.fillStyle = '#60727d'; ctx.fillRect(px,py,TILE,TILE);
      ctx.fillStyle = '#7f8e98';
      ctx.beginPath();
      ctx.moveTo(px+7,py+25); ctx.lineTo(px+12,py+10); ctx.lineTo(px+26,py+13); ctx.lineTo(px+22,py+26); ctx.closePath();
      ctx.fill();
      ctx.fillStyle = 'rgba(255,255,255,.08)'; ctx.fillRect(px+10,py+12,5,3);
    }

    if(t.item){
      const c = t.item === 'heal' ? '#ff8fb1' : t.item === 'speed' ? '#7ce0ff' : '#ffd166';
      ctx.save();
      ctx.translate(px+TILE/2, py+TILE/2);
      ctx.fillStyle = c;
      ctx.beginPath(); ctx.arc(0,0,7,0,Math.PI*2); ctx.fill();
      ctx.fillStyle = 'rgba(255,255,255,.45)';
      ctx.beginPath(); ctx.arc(-2,-2,2.5,0,Math.PI*2); ctx.fill();
      ctx.restore();
    }
    if(t.trap){
      ctx.fillStyle = 'rgba(255,70,70,.72)';
      ctx.beginPath(); ctx.arc(px+TILE/2, py+TILE/2, 7, 0, Math.PI*2); ctx.fill();
    }
    ctx.strokeStyle = 'rgba(0,0,0,.18)';
    ctx.strokeRect(px+.5,py+.5,TILE-1,TILE-1);
  }

  function drawWeapon(p){
    const t = performance.now()/140;
    ctx.save();
    ctx.translate(p.px, p.py);
    const sx = p.facing.x, sy = p.facing.y;
    if(p.classId === 'warrior'){
      ctx.rotate(Math.atan2(sy,sx));
      ctx.strokeStyle = '#d9e6ef';
      ctx.lineWidth = 4;
      ctx.beginPath(); ctx.moveTo(4,-1); ctx.lineTo(17, -1 + Math.sin(t)*1.5); ctx.stroke();
      ctx.fillStyle = '#b38b59'; ctx.fillRect(1,-4,4,8);
    } else if(p.classId === 'archer'){
      ctx.rotate(Math.atan2(sy,sx));
      ctx.strokeStyle = '#7b4a24';
      ctx.lineWidth = 3;
      ctx.beginPath(); ctx.arc(0,0,11,-1.2,1.2); ctx.stroke();
      ctx.strokeStyle = '#efe5bf';
      ctx.beginPath(); ctx.moveTo(0,-11); ctx.lineTo(12,0); ctx.lineTo(0,11); ctx.stroke();
    } else {
      ctx.fillStyle = '#cbd3ff';
      ctx.beginPath(); ctx.arc(13*Math.sign(sx || 1), -10, 7, 0, Math.PI*2); ctx.fill();
      ctx.strokeStyle = '#8aa3ff';
      ctx.lineWidth = 3;
      ctx.beginPath(); ctx.moveTo(0,-2); ctx.lineTo(12*Math.sign(sx || 1), -10); ctx.stroke();
    }
    ctx.restore();
  }

  function drawPlayer(p){
    if(!p.alive) return;
    const anim = performance.now()/180;
    const bob = p.moving ? Math.sin(anim*2.4)*1.6 : Math.sin(anim + p.id)*1.1;
    ctx.save();
    ctx.translate(p.px, p.py + bob);
    ctx.shadowColor = p.color;
    ctx.shadowBlur = p.hitFlash > 0 ? 18 : 8;

    ctx.fillStyle = 'rgba(0,0,0,.25)';
    ctx.beginPath(); ctx.ellipse(0, 14, 13, 7, 0, 0, Math.PI*2); ctx.fill();

    ctx.fillStyle = '#10222d';
    ctx.beginPath(); ctx.roundRect(-11,-17,22,30,8); ctx.fill();

    ctx.fillStyle = p.classId === 'mage' ? '#bbd8ff' : p.classId === 'archer' ? '#8f6d3e' : '#e8d2b2';
    ctx.beginPath(); ctx.arc(0,-7,6,0,Math.PI*2); ctx.fill();

    const grad = ctx.createLinearGradient(-10,-6,10,15);
    grad.addColorStop(0, p.color);
    grad.addColorStop(1, '#ffffff');
    ctx.fillStyle = grad;
    ctx.beginPath(); ctx.roundRect(-9,-2,18,19,6); ctx.fill();

    ctx.fillStyle = p.classId === 'warrior' ? '#7b3e2e' : p.classId === 'archer' ? '#315f3c' : '#3b4a8a';
    ctx.fillRect(-8,7,16,3);

    ctx.fillStyle = '#101820';
    ctx.fillRect(-4,-9,2,2);
    ctx.fillRect(2,-9,2,2);

    drawWeapon(p);

    ctx.font = '15px system-ui';
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';
    ctx.fillText(CLASSES[p.classId].icon, 0, -25);

    if(performance.now() < p.shieldUntil){
      ctx.strokeStyle = '#ffd166';
      ctx.lineWidth = 3;
      ctx.beginPath(); ctx.arc(0,0,21,0,Math.PI*2); ctx.stroke();
    }
    if(performance.now() < p.stunnedUntil) ctx.fillText('💫', 16, -16);
    if(performance.now() < p.frozenUntil) ctx.fillText('🧊', -16, -16);

    ctx.restore();
  }

  function drawProjectile(pr){
    ctx.save();
    ctx.translate(pr.px, pr.py);
    if(pr.type === 'homing'){
      const t = performance.now()/120;
      ctx.fillStyle = '#7ce0ff';
      ctx.shadowColor = '#7ce0ff';
      ctx.shadowBlur = 14;
      ctx.beginPath(); ctx.arc(0,0,7 + Math.sin(t)*1,0,Math.PI*2); ctx.fill();
      ctx.fillStyle = '#ffffff';
      ctx.beginPath(); ctx.arc(-2,-2,2,0,Math.PI*2); ctx.fill();
    } else {
      const ang = Math.atan2(pr.vy, pr.vx);
      ctx.rotate(ang);
      ctx.strokeStyle = pr.color;
      ctx.lineWidth = 3;
      ctx.shadowColor = pr.color;
      ctx.shadowBlur = 10;
      ctx.beginPath(); ctx.moveTo(-6,0); ctx.lineTo(7,0); ctx.stroke();
      ctx.beginPath(); ctx.moveTo(4,-3); ctx.lineTo(7,0); ctx.lineTo(4,3); ctx.fillStyle = pr.color; ctx.fill();
    }
    ctx.restore();
  }

  function drawStorm(s, now){
    const px = s.x*TILE, py = s.y*TILE;
    const alpha = 0.16 + 0.12*Math.sin((now/140)+(s.x+s.y));
    ctx.fillStyle = `rgba(120,180,255,${alpha})`;
    ctx.fillRect(px,py,TILE,TILE);
    ctx.fillStyle = 'rgba(255,255,255,.5)';
    ctx.beginPath(); ctx.arc(px+8, py+10, 4, 0, Math.PI*2); ctx.fill();
    ctx.beginPath(); ctx.arc(px+20, py+12, 5, 0, Math.PI*2); ctx.fill();
    ctx.fillStyle = 'rgba(255,220,120,.9)';
    ctx.fillRect(px+14, py+14, 3, 10);
  }

  function drawParticles(dt){
    state.particles = state.particles.filter(p => { p.life -= dt; return p.life > 0; });
    for(const p of state.particles){
      p.x += p.vx * 18 * dt;
      p.y += p.vy * 18 * dt;
      p.vy += 12 * dt;
      ctx.globalAlpha = clamp(p.life,0,1);
      ctx.fillStyle = p.c;
      ctx.beginPath(); ctx.arc(p.x,p.y,2,0,Math.PI*2); ctx.fill();
      ctx.globalAlpha = 1;
    }
  }

  function drawWorld(now, dt){
    const w = arena.clientWidth, h = arena.clientHeight;
    ctx.clearRect(0,0,w,h);
    const shakeX = state.shake ? rand(-state.shake,state.shake) : 0;
    const shakeY = state.shake ? rand(-state.shake,state.shake) : 0;
    ctx.save();
    ctx.translate(shakeX, shakeY);
    for(let y=0;y<MAP_H;y++) for(let x=0;x<MAP_W;x++) drawTile(x,y,state.map[y][x]);
    for(const s of state.storms) drawStorm(s, now);
    for(const pr of state.projectiles) drawProjectile(pr);
    for(const p of state.players) drawPlayer(p);
    drawParticles(dt);
    ctx.restore();
    state.shake = Math.max(0, state.shake - 0.35);
  }

  function tick(now){
    const dt = Math.min(0.033, (now - state.last)/1000);
    state.last = now;
    if(state.running && !state.winner){
      updatePlayers(now);
      updateProjectiles(dt);
      updateStorms(now);
      updateHUD();
      drawWorld(now, dt);
    } else if(state.running){
      drawWorld(now, dt);
    }
    requestAnimationFrame(tick);
  }

  window.addEventListener('keydown', (e) => {
    const key = e.key;
    if(['ArrowUp','ArrowDown','ArrowLeft','ArrowRight','Tab',' '].includes(key)) e.preventDefault();
    if(state.pressed.has(key)) return;
    state.pressed.add(key);
    handleKeyPress(key);
  });
  window.addEventListener('keyup', (e) => state.pressed.delete(e.key));

  function handleKeyPress(key){
    if(!state.running || !state.introDone || state.winner) return;
    const p1 = state.players[0];
    const p2 = state.players[1];
    const lower = key.toLowerCase();

    if(key === 'ArrowUp') attemptMove(p1,0,-1);
    if(key === 'ArrowDown') attemptMove(p1,0,1);
    if(key === 'ArrowLeft') attemptMove(p1,-1,0);
    if(key === 'ArrowRight') attemptMove(p1,1,0);
    if(key === '1') handleSpecial(p1,'s1');
    if(key === '2') handleSpecial(p1,'s2');
    if(key === '3') handleSpecial(p1,'s3');
    if(key === '4') attackBasic(p1);

    if(lower === 'w') attemptMove(p2,0,-1);
    if(lower === 's') attemptMove(p2,0,1);
    if(lower === 'a') attemptMove(p2,-1,0);
    if(lower === 'd') attemptMove(p2,1,0);
    if(key === '8') handleSpecial(p2,'s1');
    if(key === '9') handleSpecial(p2,'s2');
    if(key === '0') handleSpecial(p2,'s3');
    if(key === '7') attackBasic(p2);
  }

  startBtn.onclick = () => {
    startScreen.classList.add('active');
    tutorialScreen.classList.remove('active');
    buildClassCards();
  };
  tutorialBtn.onclick = () => {
    startScreen.classList.remove('active');
    tutorialScreen.classList.add('active');
  };
  backBtn.onclick = () => {
    tutorialScreen.classList.remove('active');
    startScreen.classList.add('active');
  };
  playBtn.onclick = () => startGame();

  buildClassCards();
  resizeCanvas();
  requestAnimationFrame(tick);
})();
</script>
</body>
</html>
